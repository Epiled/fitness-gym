{{!-- 
  Base @font-face template used by the icon font pipeline.
  This template defines the font-family and source paths.
 
  Variables:
   - fontName    → Font family name
   - fontPath    → Base path for font assets
   - folderName  → Font output directory
--}}

@font-face {
  font-family: '{{fontName}}';
  src: 
    url('{{fontPath}}/{{folderName}}/{{fontName}}.woff2') format('woff2'),
    url('{{fontPath}}/{{folderName}}/{{fontName}}.woff') format('woff'),
    url('{{fontPath}}/{{folderName}}/{{fontName}}.ttf') format('truetype');
  font-weight: normal;
  font-style: normal;
  font-display: swap;
}
